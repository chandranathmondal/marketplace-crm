# Copy to .env if you want to keep local backend details near the project.
# The extension reads these from its Settings page, not directly from this file.
# However, during development, these values will be automatically loaded into browser storage on first run.
VITE_MARKETPLACE_CRM_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
VITE_MARKETPLACE_CRM_SPREADSHEET_ID=YOUR_GOOGLE_SHEET_ID
